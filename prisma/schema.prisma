generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Partner {
  id              String           @id @default(uuid())
  phone           String           @unique
  role            PartnerRole
  city            String?
  isActive        Boolean          @default(true)
  isAvailable     Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  status          PartnerStatus    @default(PENDING)
  address         String?
  businessName    String?
  email           String?
  experience      String?
  fullName        String
  partnerType     String
  token           String?          @unique
  cookProfile     CookProfile?
  deliveryPartner DeliveryPartner?
  designerProfile DesignerProfile?
  laundryShop     LaundryShop?
  meatShop        MeatShop?
  organicShop     OrganicShop?

  @@map("Partner")
}

model DesignerProfile {
  id          String             @id @default(uuid())
  partnerId   String             @unique
  bio         String?
  specialties String[]
  avatar      String?
  coverImage  String?
  experience  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  portfolio   Design[]
  categories  DesignerCategory[]
  partner     Partner            @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("DesignerProfile")
}

model Design {
  id                   String          @id @default(uuid())
  designerId           String
  title                String
  description          String?
  category             String
  subcategory          String?
  price                Float
  currency             String          @default("₹")
  images               String[]
  tags                 String[]
  isTrending           Boolean         @default(false)
  isNew                Boolean         @default(true)
  likes                Int             @default(0)
  views                Int             @default(0)
  inquiries            Int             @default(0)
  status               String          @default("published")
  fabricType           String?
  deliveryTime         String?
  readyToWear          Boolean         @default(false)
  customizationOptions String[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  designer             DesignerProfile @relation(fields: [designerId], references: [id], onDelete: Cascade)

  @@index([designerId])
  @@index([category])
  @@index([isTrending])
  @@map("Design")
}

model DesignerCategory {
  id            String                @id @default(uuid())
  designerId    String
  name          String
  isDefault     Boolean               @default(false)
  displayOrder  Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  designer      DesignerProfile       @relation(fields: [designerId], references: [id], onDelete: Cascade)
  subcategories DesignerSubcategory[]

  @@unique([designerId, name])
  @@map("DesignerCategory")
}

model DesignerSubcategory {
  id           String           @id @default(uuid())
  categoryId   String
  name         String
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  items        DesignerItem[]
  category     DesignerCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@map("DesignerSubcategory")
}

model DesignerItem {
  id                String              @id @default(uuid())
  subcategoryId     String
  name              String
  description       String?
  price             Float
  discountPrice     Float?
  currency          String              @default("₹")
  images            String[]
  videos            String[]
  availability      String
  measurements      Json?
  deliveryTime      String?
  customizationTime String?
  isActive          Boolean             @default(true)
  views             Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  subcategory       DesignerSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  sizes             Size[]

  @@index([subcategoryId])
  @@map("DesignerItem")
}

model Size {
  id      String       @id @default(uuid())
  itemId  String
  size    String
  inStock Boolean      @default(true)
  item    DesignerItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, size])
  @@map("Size")
}

model LaundryShop {
  id        String   @id @default(uuid())
  partnerId String   @unique
  shopName  String
  address   String?
  city      String?
  lat       Float?
  lng       Float?
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("LaundryShop")
}

model MeatShop {
  id        String     @id @default(uuid())
  partnerId String     @unique
  shopName  String
  address   String?
  city      String?
  lat       Float?
  lng       Float?
  isOpen    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  closeTime String?
  openTime  String?
  items     MeatItem[]
  partner   Partner    @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("MeatShop")
}

model MeatItem {
  id         String   @id @default(uuid())
  meatShopId String
  name       String
  unit       String
  price      Float
  minQty     Float?
  stepQty    Float?
  inStock    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  imageUrl   String?
  images     String[]
  shop       MeatShop @relation(fields: [meatShopId], references: [id], onDelete: Cascade)

  @@index([meatShopId])
  @@map("MeatItem")
}

model OrganicShop {
  id         String            @id @default(uuid())
  partnerId  String            @unique
  shopName   String
  address    String?
  city       String?
  lat        Float?
  lng        Float?
  isOpen     Boolean           @default(true)
  openTime   String?
  closeTime  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  categories OrganicCategory[]
  items      OrganicItem[]
  partner    Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("OrganicShop")
}

model OrganicCategory {
  id            String        @id @default(cuid())
  organicShopId String
  name          String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  organicShop   OrganicShop   @relation(fields: [organicShopId], references: [id], onDelete: Cascade)
  items         OrganicItem[]

  @@unique([organicShopId, name])
  @@map("OrganicCategory")
}

model OrganicItem {
  id                String           @id @default(uuid())
  organicShopId     String
  name              String
  unit              String
  price             Float
  minQty            Float?
  stepQty           Float?
  inStock           Boolean          @default(true)
  imageUrl          String?
  images            String[]
  category          String?
  isOrganic         Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  description       String?
  stock             Int?
  organicCategoryId String?
  organicCategory   OrganicCategory? @relation(fields: [organicCategoryId], references: [id])
  shop              OrganicShop      @relation(fields: [organicShopId], references: [id], onDelete: Cascade)

  @@index([organicShopId])
  @@index([organicCategoryId])
  @@map("OrganicItem")
}

model DeliveryPartner {
  id                 String      @id @default(uuid())
  vehicleNumber      String
  isAvailable        Boolean     @default(true)
  currentLat         Float?
  currentLng         Float?
  lastLocationUpdate DateTime?
  currentOrders      Int         @default(0)
  totalDeliveries    Int         @default(0)
  rating             Float       @default(5.0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  drivingLicense     String
  isVerified         Boolean     @default(false)
  partnerId          String      @unique
  vehicleModel       String?
  vehicleType        VehicleType
  deliveries         Delivery[]
  partner            Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([isAvailable])
  @@index([currentOrders])
  @@map("DeliveryPartner")
}

model Delivery {
  id                    String          @id @default(uuid())
  orderId               String          @unique
  partnerId             String
  customerName          String
  customerPhone         String
  customerAddress       String?
  storeId               String
  storeName             String
  storeAddress          String?
  status                DeliveryStatus
  assignedAt            DateTime?       @default(now())
  arrivedAtStoreAt      DateTime?
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  estimatedPickupTime   DateTime?
  estimatedDeliveryTime DateTime?
  actualPickupTime      DateTime?
  actualDeliveryTime    DateTime?
  currentLat            Float?
  currentLng            Float?
  lastLocationUpdate    DateTime?
  pickupOtp             String?
  pickupOtpVerified     Boolean         @default(false)
  pickupOtpVerifiedAt   DateTime?
  items                 Json
  totalAmount           Float
  partner               DeliveryPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([partnerId])
  @@map("Delivery")
}

model CookProfile {
  id             String          @id @default(uuid())
  partnerId      String          @unique
  bio            String?
  experience     String?
  tier           CookTier        @default(HOME_COOK)
  pricePerHour   Float?
  pricePerPerson Float?
  minPeople      Int?
  maxPeople      Int?
  isAvailable    Boolean         @default(true)
  rating         Float           @default(0)
  reviewCount    Int             @default(0)
  avatar         String?
  coverImage     String?
  city           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       CookBooking[]
  images         CookImage[]
  menuItems      CookMenuItem[]
  partner        Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  specialties    CookSpecialty[]
  cuisines       Cuisine[]

  @@map("CookProfile")
}

model Cuisine {
  id            String      @id @default(uuid())
  name          String
  cookProfileId String
  cookProfile   CookProfile @relation(fields: [cookProfileId], references: [id], onDelete: Cascade)

  @@unique([cookProfileId, name])
  @@map("Cuisine")
}

model CookSpecialty {
  id            String      @id @default(uuid())
  name          String
  cookProfileId String
  cookProfile   CookProfile @relation(fields: [cookProfileId], references: [id], onDelete: Cascade)

  @@unique([cookProfileId, name])
  @@map("CookSpecialty")
}

model CookImage {
  id            String      @id @default(uuid())
  url           String
  cookProfileId String
  isCover       Boolean     @default(false)
  createdAt     DateTime    @default(now())
  cookProfile   CookProfile @relation(fields: [cookProfileId], references: [id], onDelete: Cascade)

  @@map("CookImage")
}

model CookMenuItem {
  id            String       @id @default(uuid())
  name          String
  description   String?
  price         Float
  category      MenuCategory
  cuisine       String?
  isVegetarian  Boolean      @default(false)
  isVegan       Boolean      @default(false)
  isGlutenFree  Boolean      @default(false)
  isSignature   Boolean      @default(false)
  imageUrl      String?
  cookProfileId String
  cookProfile   CookProfile  @relation(fields: [cookProfileId], references: [id], onDelete: Cascade)

  @@index([cookProfileId])
  @@map("CookMenuItem")
}

model CookBooking {
  id              String        @id @default(uuid())
  cookProfileId   String
  customerName    String
  customerPhone   String
  customerAddress String?
  date            DateTime
  timeSlot        String
  numberOfPeople  Int
  specialRequests String?
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cookProfile     CookProfile   @relation(fields: [cookProfileId], references: [id], onDelete: Cascade)

  @@index([cookProfileId])
  @@index([status])
  @@map("CookBooking")
}

model Coupon {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @unique
  description     String?
  discount_type   String?
  discount_value  Decimal?  @db.Decimal(10, 2)
  max_discount    Decimal?  @db.Decimal(10, 2)
  min_order_value Decimal?  @db.Decimal(10, 2)
  service_type    String?
  expiry_date     DateTime? @db.Timestamp(6)
  usage_limit     Int?
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  @@map("coupon")
}

model OrderPayment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String?   @db.Uuid
  payment_method  String?
  payment_gateway String?
  transaction_id  String?
  status          String?
  amount          Decimal?  @db.Decimal(10, 2)
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  @@map("order_payment")
}

model ServiceFeeConfig {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_type    String
  fee_code        String
  fee_label       String
  fee_type        String
  amount          Decimal   @db.Decimal(10, 2)
  min_order_value Decimal?  @db.Decimal(10, 2)
  city            String?
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)

  @@map("service_fee_config")
}

model SubscriptionPlan {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  price         Decimal?  @db.Decimal(10, 2)
  duration_days Int?
  benefits      Json?
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@map("subscription_plan")
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("PartnerStatus")
}

enum PartnerRole {
  LAUNDRY_PARTNER
  MEAT_PARTNER
  TAILOR
  COOK
  DELIVERY
  ORGANIC_PARTNER

  @@map("PartnerRole")
}

enum DeliveryStatus {
  ASSIGNED
  ACCEPTED
  ON_THE_WAY_TO_STORE
  ARRIVED_AT_STORE
  PICKED_UP
  ON_THE_WAY
  ARRIVED
  DELIVERED
  FAILED
  CANCELLED

  @@map("DeliveryStatus")
}

enum VehicleType {
  SCOOTY
  BIKE
  CAR

  @@map("VehicleType")
}

enum CookTier {
  HOME_COOK
  EXPERIENCED
  PROFESSIONAL
  CHEF

  @@map("CookTier")
}

enum MenuCategory {
  STARTER
  MAIN_COURSE
  SIDE_DISH
  DESSERT
  BEVERAGE
  BREAD
  RICE
  CURRY
  TANDOOR
  BBQ
  BIRYANI
  THALI

  @@map("MenuCategory")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("BookingStatus")
}

model Customer {
  id          String            @id @default(uuid())
  fullName    String
  phone       String            @unique
  email       String?
  passwordHash String
  token       String?           @unique
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  addresses   CustomerAddress[]

  @@map("Customer")
}

model CustomerAddress {
  id           String    @id @default(uuid())
  customerId   String
  label        String?
  fullAddress  String
  city         String?
  lat          Float?
  lng          Float?
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("CustomerAddress")
}

model CustomerOrder {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber       String   @unique
  serviceType       String
  storeType         String
  storeId           String
  storeName         String
  customerName      String
  customerPhone     String
  customerAddress   String
  customerLat       Float?
  customerLng       Float?
  paymentMethod     String
  paymentStatus     String              @default("PENDING_CASH_COLLECTION")
  orderStatus       String              @default("PLACED")
  couponCode        String?
  subtotal          Decimal             @db.Decimal(10, 2)
  packagingCharge   Decimal             @default(0) @db.Decimal(10, 2)
  deliveryFee       Decimal             @default(0) @db.Decimal(10, 2)
  platformFee       Decimal             @default(0) @db.Decimal(10, 2)
  handlingFee       Decimal             @default(0) @db.Decimal(10, 2)
  gst               Decimal             @default(0) @db.Decimal(10, 2)
  restaurantGst     Decimal             @default(0) @db.Decimal(10, 2)
  gstOnDeliveryFee  Decimal             @default(0) @db.Decimal(10, 2)
  lateNightFee      Decimal             @default(0) @db.Decimal(10, 2)
  discount          Decimal             @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal             @db.Decimal(10, 2)
  deliveryId        String?             @unique @db.Uuid
  deliveryPartnerId String?             @db.Uuid
  placedAt          DateTime            @default(now()) @db.Timestamp(6)
  acceptedAt        DateTime?           @db.Timestamp(6)
  rejectedAt        DateTime?           @db.Timestamp(6)
  readyForPickupAt  DateTime?           @db.Timestamp(6)
  deliveredAt       DateTime?           @db.Timestamp(6)
  cashCollectedAt   DateTime?           @db.Timestamp(6)
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  updatedAt         DateTime            @default(now()) @updatedAt @db.Timestamp(6)

  items             CustomerOrderItem[]
  statusHistory     OrderStatusHistory[]

  @@index([storeId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([deliveryId])
  @@map("customer_order")
}

model CustomerOrderItem {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String        @db.Uuid
  itemId     String
  itemName   String
  unit       String?
  price      Decimal       @db.Decimal(10, 2)
  quantity   Decimal       @db.Decimal(10, 2)
  lineTotal  Decimal       @db.Decimal(10, 2)
  imageUrl   String?
  createdAt  DateTime      @default(now()) @db.Timestamp(6)

  order      CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("customer_order_item")
}

model OrderStatusHistory {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String        @db.Uuid
  status     String
  note       String?
  actorType  String?
  actorId    String?
  createdAt  DateTime      @default(now()) @db.Timestamp(6)

  order      CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("order_status_history")
}